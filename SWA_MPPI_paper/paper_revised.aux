\@writefile{lot}{\contentsline {table}{\numberline {17}{\ignorespaces Per-country JSD for the four consensus-shift baselines on Llama-3.1-70B (15 countries). \textsc  {CS-Clamp} is the strongest deterministic shift but still loses to SWA-PTIS in aggregate; \textsc  {CS-Std} is catastrophic for NGA ($+0.017$ vs.\ \textsc  {CS-Mean}) due to unbounded variance amplification.}}{23}{table.caption.42}\protected@file@percent }
\newlabel{tab:consensus_shift_country}{{17}{23}{Per-country JSD for the four consensus-shift baselines on Llama-3.1-70B (15 countries). \textsc {CS-Clamp} is the strongest deterministic shift but still loses to SWA-PTIS in aggregate; \textsc {CS-Std} is catastrophic for NGA ($+0.017$ vs.\ \textsc {CS-Mean}) due to unbounded variance amplification}{table.caption.42}{}}
\@writefile{lot}{\contentsline {table}{\numberline {18}{\ignorespaces Binary-ARGS per-country results (Llama-3.1-70B, 15 countries). \textsc  {ARGS-PT} achieves best or tied JSD in 13/15 countries and best $r$ in 11/15, confirming SWA-PTIS is precisely an ARGS variant with KL-regularised Prospect-Theory utility.}}{23}{table.caption.43}\protected@file@percent }
